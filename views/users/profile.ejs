<%- layout("/layouts/boilerplate") %>

<div class="row mt-3">
    <div class="col-10 offset-1">
        <h1>@<%= currUser.username %></h1>
        <p class="text-muted"><%= currUser.email %></p>

        <hr>

        <h3 class="mt-4">My Listings</h3>
        <% if (listings.length === 0) { %>
            <p class="text-muted">You haven't created any listings yet. <a href="/listings/new">Create one</a>.</p>
        <% } %>
        <div class="row g-3">
            <% listings.forEach(function(listing) { %>
                <div class="col-lg-4 col-md-6 col-sm-12">
                    <article class="card h-100">
                        <img src="<%= listing.image.url %>" class="card-img-top" style="height: 10rem; object-fit: cover;" alt="listing image">
                        <div class="card-body">
                            <h5 class="card-title"><a href="/listings/<%= listing._id %>"><%= listing.title %></a></h5>
                            <p class="card-text">&#8377;<%= listing.price.toLocaleString("en-IN") %> /night</p>
                        </div>
                        <div class="px-3 pb-3 d-flex gap-2">
                            <a href="/listings/<%= listing._id %>/edit" class="btn btn-sm btn-dark w-50">Edit</a>
                            <form class="w-50" method="post" action="/listings/<%= listing._id %>?_method=DELETE">
                                <button class="btn btn-sm btn-outline-dark w-100" type="submit">Delete</button>
                            </form>
                        </div>
                    </article>
                </div>
            <% }); %>
        </div>

        <hr class="mt-4">

        <h3 class="mt-4">My Trips</h3>
        <% if (trips.length === 0) { %>
            <p class="text-muted">You have no upcoming trips. <a href="/listings">Explore listings</a>.</p>
        <% } %>
        <div class="row g-3">
            <% trips.forEach(function(trip) { %>
                <div class="col-lg-4 col-md-6 col-sm-12">
                    <article class="card h-100">
                        <div class="card-body">
                            <h5 class="card-title">
                                <% if (trip.listing) { %>
                                    <a href="/listings/<%= trip.listing._id %>"><%= trip.listing.title %></a>
                                <% } else { %>
                                    Listing no longer available
                                <% } %>
                            </h5>
                            <p class="card-text"><%= trip.checkIn.toDateString() %> &rarr; <%= trip.checkOut.toDateString() %></p>
                            <p class="card-text">Total: &#8377;<%= trip.totalPrice.toLocaleString("en-IN") %></p>
                        </div>
                    </article>
                </div>
            <% }); %>
        </div>
    </div>
</div>
