<%- layout("/layouts/boilerplate") %>

<body>
<div class="filter-strip-wrap">
    <div class="category-strip" role="tablist" aria-label="Browse by category">
        <a class="category-chip <%= !selectedCategory ? 'is-active' : '' %>" href="/listings<%= searchQuery ? '?q=' + encodeURIComponent(searchQuery) : '' %>">
            <span class="category-chip-icon"><i class="fa-solid fa-compass"></i></span>
            <span class="category-chip-label">All</span>
        </a>
        <a class="category-chip <%= selectedCategory === 'Trending' ? 'is-active' : '' %>" href="/listings?category=Trending<%= searchQuery ? '&q=' + encodeURIComponent(searchQuery) : '' %>">
            <span class="category-chip-icon"><i class="fa-solid fa-fire"></i></span>
            <span class="category-chip-label">Trending</span>
        </a>
        <a class="category-chip <%= selectedCategory === 'Rooms' ? 'is-active' : '' %>" href="/listings?category=Rooms<%= searchQuery ? '&q=' + encodeURIComponent(searchQuery) : '' %>">
            <span class="category-chip-icon"><i class="fa-solid fa-bed"></i></span>
            <span class="category-chip-label">Rooms</span>
        </a>
        <a class="category-chip <%= selectedCategory === 'Iconic Cities' ? 'is-active' : '' %>" href="/listings?category=Iconic%20Cities<%= searchQuery ? '&q=' + encodeURIComponent(searchQuery) : '' %>">
            <span class="category-chip-icon"><i class="fa-solid fa-city"></i></span>
            <span class="category-chip-label">Iconic Cities</span>
        </a>
        <a class="category-chip <%= selectedCategory === 'Mountains' ? 'is-active' : '' %>" href="/listings?category=Mountains<%= searchQuery ? '&q=' + encodeURIComponent(searchQuery) : '' %>">
            <span class="category-chip-icon"><i class="fa-solid fa-mountain"></i></span>
            <span class="category-chip-label">Mountains</span>
        </a>
        <a class="category-chip <%= selectedCategory === 'Castles' ? 'is-active' : '' %>" href="/listings?category=Castles<%= searchQuery ? '&q=' + encodeURIComponent(searchQuery) : '' %>">
            <span class="category-chip-icon"><i class="fa-solid fa-chess-rook"></i></span>
            <span class="category-chip-label">Castles</span>
        </a>
        <a class="category-chip <%= selectedCategory === 'Beachfront' ? 'is-active' : '' %>" href="/listings?category=Beachfront<%= searchQuery ? '&q=' + encodeURIComponent(searchQuery) : '' %>">
            <span class="category-chip-icon"><i class="fa-solid fa-umbrella-beach"></i></span>
            <span class="category-chip-label">Beachfront</span>
        </a>
        <a class="category-chip <%= selectedCategory === 'Lakefront' ? 'is-active' : '' %>" href="/listings?category=Lakefront<%= searchQuery ? '&q=' + encodeURIComponent(searchQuery) : '' %>">
            <span class="category-chip-icon"><i class="fa-solid fa-water"></i></span>
            <span class="category-chip-label">Lakefront</span>
        </a>
        <a class="category-chip <%= selectedCategory === 'Luxury' ? 'is-active' : '' %>" href="/listings?category=Luxury<%= searchQuery ? '&q=' + encodeURIComponent(searchQuery) : '' %>">
            <span class="category-chip-icon"><i class="fa-solid fa-gem"></i></span>
            <span class="category-chip-label">Luxury</span>
        </a>
        <a class="category-chip <%= selectedCategory === 'Historic Stays' ? 'is-active' : '' %>" href="/listings?category=Historic%20Stays<%= searchQuery ? '&q=' + encodeURIComponent(searchQuery) : '' %>">
            <span class="category-chip-icon"><i class="fa-solid fa-landmark"></i></span>
            <span class="category-chip-label">Historic Stays</span>
        </a>
        <a class="category-chip <%= selectedCategory === 'Amazing Pools' ? 'is-active' : '' %>" href="/listings?category=Amazing%20Pools<%= searchQuery ? '&q=' + encodeURIComponent(searchQuery) : '' %>">
            <span class="category-chip-icon"><i class="fa-solid fa-water-ladder"></i></span>
            <span class="category-chip-label">Amazing Pools</span>
        </a>
        <a class="category-chip <%= selectedCategory === 'Camping' ? 'is-active' : '' %>" href="/listings?category=Camping<%= searchQuery ? '&q=' + encodeURIComponent(searchQuery) : '' %>">
            <span class="category-chip-icon"><i class="fa-solid fa-campground"></i></span>
            <span class="category-chip-label">Camping</span>
        </a>
        <a class="category-chip <%= selectedCategory === 'Farms' ? 'is-active' : '' %>" href="/listings?category=Farms<%= searchQuery ? '&q=' + encodeURIComponent(searchQuery) : '' %>">
            <span class="category-chip-icon"><i class="fa-solid fa-tractor"></i></span>
            <span class="category-chip-label">Farms</span>
        </a>
    </div>
</div>

<section class="hero-section">
    <div class="hero-blob hero-blob-1"></div>
    <div class="hero-blob hero-blob-2"></div>
    <div class="hero-inner">
        <div class="hero-kicker">
            <span class="hero-kicker-line"></span>
            <span class="hero-kicker-text">Featured city stays</span>
            <span class="hero-kicker-line"></span>
        </div>
        <h1 class="hero-headline">Where will you <span class="hero-word" id="heroWord">wake up</span>?</h1>
        <p class="hero-subtitle">Hand-picked stays in the world's most restless cities.</p>
    </div>
</section>

<% const driftListings = listings.slice(0, 8); %>
<% if (driftListings.length > 1) { %>
<div class="hero-drift-wrap">
    <div class="hero-drift-track">
        <% [driftListings, driftListings].forEach(function(set) { %>
            <% set.forEach(function(listing) { %>
                <a href="/listings/<%= listing._id %>" class="hero-drift-card" style="background-image: linear-gradient(to top, rgba(9,7,6,0.85) 5%, rgba(9,7,6,0.05) 55%), url('<%= listing.image.url %>');">
                    <span class="hero-drift-title"><%= listing.title %></span>
                    <span class="hero-drift-price">&#8377;<%= listing.price.toLocaleString("en-IN") %> /night</span>
                </a>
            <% }); %>
        <% }); %>
    </div>
</div>
<% } %>

<div class="marquee-strip" aria-hidden="true">
    <div class="marquee-track">
        <span class="marquee-text">City stays &middot; Lofts &middot; Rooftops &middot; Terraces &middot; Penthouses &middot; Studios &middot; City stays &middot; Lofts &middot; Rooftops &middot; Terraces &middot; Penthouses &middot; Studios &middot;&nbsp;</span>
        <span class="marquee-text">City stays &middot; Lofts &middot; Rooftops &middot; Terraces &middot; Penthouses &middot; Studios &middot; City stays &middot; Lofts &middot; Rooftops &middot; Terraces &middot; Penthouses &middot; Studios &middot;&nbsp;</span>
    </div>
</div>

<% if ((typeof searchQuery !== 'undefined' && searchQuery) || (typeof selectedCategory !== 'undefined' && selectedCategory)) { %>
    <div class="active-filters-note">
        <% if (searchQuery) { %>
            <p class="mb-1"><b>Search:</b> "<%= searchQuery %>"</p>
        <% } %>
        <% if (selectedCategory) { %>
            <p class="mb-1"><b>Category:</b> <%= selectedCategory %></p>
        <% } %>
        <% if (listings.length === 0) { %>
            <p class="text-muted mb-0">No listings found. Try another keyword.</p>
        <% } %>
    </div>
<% } %>

<div class="listings-grid-wrap">
    <div class="row row-cols-1 row-cols-sm-1 row-cols-md-2 row-cols-lg-3 row-cols-xl-4">
       <% for (let listing of listings){ %>
        <a href="/listings/<%= listing._id %>" class="listing-link">
             <div class="card col listing-card">
        <img src="<%= listing.image.url %>"
        class="card-img-top listing-thumb"
        alt="listing_img"/>
        <div class="card-img-overlay">
            <span class="card-hover-hint">View listing &rarr;</span>
        </div>
        <div class="card-body">
            <p class="card-text"><b><%=listing.title %></b>
            <br>
            <span class="rating-line">
                <% if (listing.reviews && listing.reviews.length > 0) { %>
                    <i class="fa-solid fa-star"></i> <%= avgRating(listing.reviews).toFixed(1) %> (<%= listing.reviews.length %>)
                <% } else { %>
                    New
                <% } %>
            </span>
            <br>
            <%=listing.description %>
            <br>
             &#8377;<%= listing.price.toLocaleString("en-IN") %> /night
            <br>
        </p>
        </div>
    </div>
        </a>

 <%}%>
    </div>
</div>

</body>
