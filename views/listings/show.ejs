<%- layout("/layouts/boilerplate") %>

<section class="listing-detail-page">
    <div class="detail-header mt-4 mb-3">
        <h1><%= listing.title %></h1>
        <p class="detail-subtitle"><%= listing.location %>, <%= listing.country %></p>
        <p class="detail-subtitle">
            <% if (listing.reviews && listing.reviews.length > 0) { %>
                <i class="fa-solid fa-star"></i> <%= avgRating(listing.reviews).toFixed(1) %> (<%= listing.reviews.length %> review<%= listing.reviews.length === 1 ? '' : 's' %>)
            <% } else { %>
                New listing &mdash; no reviews yet
            <% } %>
        </p>
    </div>

    <div class="detail-grid">
        <article class="card listing-card detail-main-card">
            <% if (listing.images && listing.images.length > 0) { %>
                <div id="listingCarousel" class="carousel slide" data-bs-ride="carousel">
                    <div class="carousel-inner">
                        <div class="carousel-item active">
                            <img src="<%= listing.image.url %>" class="card-img-top show-img" alt="listing image">
                        </div>
                        <% listing.images.forEach(function(img) { %>
                            <div class="carousel-item">
                                <img src="<%= img.url %>" class="card-img-top show-img" alt="listing image">
                            </div>
                        <% }); %>
                    </div>
                    <button class="carousel-control-prev" type="button" data-bs-target="#listingCarousel" data-bs-slide="prev">
                        <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                        <span class="visually-hidden">Previous</span>
                    </button>
                    <button class="carousel-control-next" type="button" data-bs-target="#listingCarousel" data-bs-slide="next">
                        <span class="carousel-control-next-icon" aria-hidden="true"></span>
                        <span class="visually-hidden">Next</span>
                    </button>
                </div>
            <% } else { %>
                <img src="<%= listing.image.url %>" class="card-img-top show-img" alt="listing image">
            <% } %>
            <div class="card-body detail-content">
                <p class="detail-owner">Owned by: <strong><%= listing.owner ? listing.owner.username : "Unknown host" %></strong></p>
                <p class="detail-description"><%= listing.description %></p>
                <div class="detail-meta">
                    <span class="meta-pill">Price: &#8377; <%= listing.price.toLocaleString("en-IN") %> / night</span>
                    <span class="meta-pill"><%= listing.location %></span>
                    <span class="meta-pill"><%= listing.country %></span>
                </div>
            </div>
        </article>
    </div>

    <div class="detail-actions-row mt-3 mb-2">
        <a href="/listings/<%= listing._id %>/edit" class="btn btn-dark">Edit Listing</a>
        <form method="post" action="/listings/<%= listing._id %>?_method=DELETE">
            <button class="btn btn-outline-dark" type="submit">Delete Listing</button>
        </form>
    </div>

    <hr>

    <% if (isOwnerViewing) { %>
        <section class="owner-bookings-section mt-4">
            <h4><b>Incoming Bookings</b></h4>
            <% if (ownerBookings && ownerBookings.length > 0) { %>
                <div class="row g-3">
                    <% ownerBookings.forEach(function(b) { %>
                        <div class="col-lg-4 col-md-6 col-sm-12">
                            <article class="card h-100">
                                <div class="card-body">
                                    <h5 class="card-title">@<%= b.user ? b.user.username : "guest" %></h5>
                                    <p class="card-text"><%= b.checkIn.toDateString() %> &rarr; <%= b.checkOut.toDateString() %></p>
                                    <p class="card-text">Guests: <%= b.guests %></p>
                                    <p class="card-text">Total: &#8377;<%= b.totalPrice.toLocaleString("en-IN") %></p>
                                </div>
                            </article>
                        </div>
                    <% }); %>
                </div>
            <% } else { %>
                <p class="text-muted">No bookings yet for this listing.</p>
            <% } %>
        </section>
    <% } else { %>
        <section class="reserve-section mt-4">
            <h4><b>Reserve your stay</b></h4>
            <form method="post" action="/bookings/<%= listing._id %>" class="reserve-form mt-3">
                <div class="row g-2">
                    <div class="col-md-4">
                        <label class="form-label" for="checkIn">Check-in:</label>
                        <input type="date" class="form-control" id="checkIn" name="booking[checkIn]" required>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label" for="checkOut">Check-out:</label>
                        <input type="date" class="form-control" id="checkOut" name="booking[checkOut]" required>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label" for="guests">Guests:</label>
                        <input type="number" class="form-control" id="guests" name="booking[guests]" min="1" value="1" required>
                    </div>
                </div>
                <button type="submit" class="btn btn-dark mt-3">Reserve</button>
            </form>
        </section>
    <% } %>

    <hr>

    <section class="reviews-section mt-4">
        <h4><b>Leave a Review</b></h4>
        <form action="/listings/<%= listing._id %>/reviews" method="post" novalidate class="needs-validation detail-review-form mt-3">
            <div class="mb-3 mt-3">
                <label class="form-label" for="rating">Rating:</label>
                <fieldset class="starability-slot">
                    <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="1" checked aria-label="No rating." />
                    <input type="radio" id="first-rate1" name="review[rating]" value="1" />
                    <label for="first-rate1" title="Terrible">1 star</label>
                    <input type="radio" id="first-rate2" name="review[rating]" value="2" />
                    <label for="first-rate2" title="Not good">2 stars</label>
                    <input type="radio" id="first-rate3" name="review[rating]" value="3" />
                    <label for="first-rate3" title="Average">3 stars</label>
                    <input type="radio" id="first-rate4" name="review[rating]" value="4" />
                    <label for="first-rate4" title="Very good">4 stars</label>
                    <input type="radio" id="first-rate5" name="review[rating]" value="5" />
                    <label for="first-rate5" title="Amazing">5 stars</label>
                </fieldset>
            </div>

            <div class="mb-3 mt-3">
                <label class="form-label" for="comment">Comment:</label>
                <textarea class="form-control" id="comment" name="review[comment]" rows="4" required></textarea>
                <div class="invalid-feedback">Please enter a valid comment.</div>
            </div>
            <button type="submit" class="btn btn-outline-dark">Submit Review</button>
        </form>
    </section>

    <hr>

    <section class="all-reviews mt-4">
        <% if(listing.reviews.length > 0){ %>
            <p class="mb-3"><b>All Reviews</b></p>
        <% } %>

        <div class="row g-3">
            <% for (review of listing.reviews) { %>
                <div class="col-lg-4 col-md-6 col-sm-12">
                    <article class="card review-card h-100">
                        <div class="card-body">
                            <h5 class="card-title">@<%= review.author ? review.author.username : "guest" %></h5>
                            <p class="starability-result card-text" data-rating="<%= review.rating %>"></p>
                            <p class="card-text"><%= review.comment %></p>
                        </div>
                        <form class="px-3 pb-3" method="post" action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE">
                            <button class="btn btn-outline-dark w-100" type="submit">Delete</button>
                        </form>
                    </article>
                </div>
            <% } %>
        </div>
    </section>

    <section class="map-section mt-4 mb-4">
        <h3>Where you'll be</h3>
        <div id="map-config" data-map-token="<%= process.env.MAP_TOKEN %>"></div>
        <script id="listing-json" type="application/json"><%- JSON.stringify(listing) %></script>
        <div id="map"></div>
    </section>
</section>

<script src="/js/map.js"></script>