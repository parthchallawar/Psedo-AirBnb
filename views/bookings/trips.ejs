<%- layout("/layouts/boilerplate") %>

<div class="row mt-3">
    <div class="col-10 offset-1">
        <h1>My Trips</h1>
        <br>
        <% if (bookings.length === 0) { %>
            <p class="text-muted">You have no upcoming trips. <a href="/listings">Explore listings</a>.</p>
        <% } %>
        <div class="row g-3">
            <% bookings.forEach(function(booking) { %>
                <div class="col-lg-4 col-md-6 col-sm-12">
                    <article class="card h-100">
                        <% if (booking.listing) { %>
                            <img src="<%= booking.listing.image.url %>" class="card-img-top" style="height: 12rem; object-fit: cover;" alt="listing image">
                        <% } %>
                        <div class="card-body">
                            <h5 class="card-title">
                                <% if (booking.listing) { %>
                                    <a href="/listings/<%= booking.listing._id %>"><%= booking.listing.title %></a>
                                <% } else { %>
                                    Listing no longer available
                                <% } %>
                            </h5>
                            <p class="card-text"><%= booking.checkIn.toDateString() %> &rarr; <%= booking.checkOut.toDateString() %></p>
                            <p class="card-text">Guests: <%= booking.guests %></p>
                            <p class="card-text">Total: &#8377;<%= booking.totalPrice.toLocaleString("en-IN") %></p>
                        </div>
                        <form class="px-3 pb-3" method="post" action="/bookings/<%= booking._id %>?_method=DELETE">
                            <button class="btn btn-outline-dark w-100" type="submit">Cancel Booking</button>
                        </form>
                    </article>
                </div>
            <% }); %>
        </div>
    </div>
</div>
